{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "pip install -r requirements.txt",
  "buildCommand": "cd Speech_enhancement && python manage.py collectstatic --noinput && python manage.py migrate --noinput",
  "builds": [
    {
      "src": "Speech_enhancement/Speech/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "Speech_enhancement/Speech/wsgi.py"
    }
  ]
}
